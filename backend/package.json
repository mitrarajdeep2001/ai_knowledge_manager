{
  "name": "ai-knowledge-manager-backend",
  "version": "1.0.0",
  "description": "AI Knowledge Manager backend API",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --clean",
    "start": "node dist/index.js",
    "worker": "tsx src/jobs/worker.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/swagger": "^8.15.0",
    "@fastify/swagger-ui": "^1.10.2",
    "@types/multer": "^2.1.0",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.70.4",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.30.10",
    "fastify": "^4.27.0",
    "fastify-multer": "^2.0.3",
    "fastify-plugin": "^4.5.1",
    "fastify-type-provider-zod": "^1.2.0",
    "fastify-zod": "^1.4.0",
    "ioredis": "^5.10.0",
    "mammoth": "^1.11.0",
    "multer": "^2.1.1",
    "pdf-parse": "^2.4.5",
    "pg": "^8.11.5",
    "zod": "^3.23.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^20.19.37",
    "@types/pg": "^8.11.6",
    "drizzle-kit": "^0.21.4",
    "tsup": "^8.5.1",
    "tsx": "^4.11.0",
    "typescript": "^5.4.5"
  }
}
